# Copy this file to .env and fill in your values (never commit .env)

# PostgreSQL
POSTGRES_DB=skyfence
POSTGRES_USER=
POSTGRES_PASSWORD=

# Spring datasource (used by the backend container)
DB_URL=jdbc:postgresql://postgres:5432/skyfence
DB_USERNAME=
DB_PASSWORD=

# Spring profile: dev | prod
SPRING_PROFILES_ACTIVE=dev

# JWT secret (mínimo 32 caracteres)
JWT_SECRET=

# Production CORS origins (comma-separated, only needed in prod)
# CORS_ALLOWED_ORIGINS=https://sky-fence.vercel.app
