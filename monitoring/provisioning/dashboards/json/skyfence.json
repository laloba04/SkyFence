      },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 48 },
      "id": 43,
      "options": { "legend": { "calcs": ["mean", "lastNotNull"], "displayMode": "table", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
